FROM python:3.12-slim

# pip 阿里云镜像源（先配 pip 源，再装包才快）
RUN pip config set global.index-url https://mirrors.aliyun.com/pypi/simple && \
    pip config set global.trusted-host mirrors.aliyun.com

# 换成中国镜像源加速
RUN sed -i 's|deb.debian.org|mirrors.aliyun.com|g' /etc/apt/sources.list.d/debian.sources && \
    apt-get update && \
    apt-get install -y --no-install-recommends \
    unzip zip tar gzip xz-utils bzip2 \
    curl wget ca-certificates \
    git build-essential \
    jq file tree \
    vim-tiny nano less \
    nodejs npm \
    sqlite3 \
    ffmpeg \
    libpango-1.0-0 libpangocairo-1.0-0 libcairo2 libgdk-pixbuf-2.0-0 libffi8 \
    && apt-get clean && rm -rf /var/lib/apt/lists/*

# 预装 Python 常用包（分批安装 + bash 重试，应对不稳定的镜像源）
# 第一批：轻量包（秒装）
RUN pip install --no-cache-dir --default-timeout=120 \
    httpx html2text beautifulsoup4 lxml requests \
    Pillow openpyxl pypdf python-docx chardet markdown weasyprint \
    || pip install --no-cache-dir --default-timeout=120 \
    httpx html2text beautifulsoup4 lxml requests \
    Pillow openpyxl pypdf python-docx chardet markdown weasyprint

# 第二批：重量级包（pandas/scipy/matplotlib 较大，单装 + 循环重试）
RUN for pkg in pandas matplotlib seaborn scipy; do \
        for i in 1 2 3; do \
            pip install --no-cache-dir --default-timeout=180 "$pkg" && break || sleep 5; \
        done; \
    done

# git 全局配置：提高大仓库性能
RUN git config --global http.postBuffer 524288000 && \
    git config --global core.compression 0

WORKDIR /workspace
